# Maintainer: Richard Hillmann <richie at project0 dot de>
pkgname=project0-sweet-gtk-themes
pkgver=20260210
pkgrel=1
pkgdesc="Sweet themes"
arch=('any')
url="https://github.com/EliverLara/Sweet.git"
license=('GNU')
conflicts=(
    sweet-gtk-theme
)

sha256sums=('c5d57ad73b900185629e590e9cd268d3af485882268baeedaf77cc100303eea9'
            '3f0a7b1b80b719ef904dbba92c27e55accb5b55cd57612cd4720c63d9ff7a5fe'
            'a9a78f4876995ee23756e8fd89731bc87f4432ebff22fecd5254ef72595220b5'
            '53339789f9a705f20f460fb4749dcb770cc588226884ef815db822aefee3a659'
            'b9c0e4620e6c549676f44ecb7ad2e92fb22f7a1bf0a529d78fa016bf880e938e')

_branches=(
    master
    mars
    nova
    Ambar
    Ambar-Blue
)

_kinds=(
    Sweet
    Sweet-mars
    Sweet-nova
    Sweet-Ambar
    Sweet-Ambar-Blue
)
_commits=(
    a5b3c824ec238f398a5b86e042d8fd74f5496244 # master
    cff8c309d987cfbedddb62330f9df8d829031e46 # mars
    2c721ad4449ab9e80f4417450270507304ce14c4 # nova
    b85cd26c87c5d38b3265e4759ceacacf79e03d74 # Ambar
    0c3d02ce438606719db854697aaea87f13a0272a # Ambar-Blue
)

function srcname () {
    c="${_commits[$1]}"
    k="${_kinds[$1]}"
    echo "git.${pkgname}-${k}-${c}"
}


for i in "${!_kinds[@]}"; do
    c="${_commits[$i]}"
    k="${_kinds[$i]}"
    source+=("$(srcname "$i")::git+${url}#commit=$c")
done

pkgver() {
    (cd "${srcdir}/$(srcname "0")" && git log -1 --format=%ad --date=format:'%Y%m%d')
}

prepare() {
    find "${srcdir}" -type f -name "*scss" -delete
    rm -rf "${srcdir}"/*/{Art,src}
    find "${srcdir}" -type d -empty -delete
}

package() {
    themes="${pkgdir}/usr/share/themes"

    for i in "${!_kinds[@]}"; do
        k="${_kinds[$i]}"
        install -dm755 "${themes}/${k}"
        cp -r "${srcdir}/$(srcname "$i")/"* "${themes}/${k}/"
    done
}
